{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:best-practices",
		"github>microsoft/vs-renovate-presets:dotnet_packages_LTS"
	],
	"semanticCommits": "disabled",
	"labels": ["dependencies"],
	"packageRules": [
		{
			"description": "Generated agentic workflow lock files are managed by 'gh aw compile' and must not be directly updated by Renovate.",
			"matchFileNames": [".github/workflows/*.lock.yml"],
			"enabled": false
		},
		{
			"matchPackageNames": ["nbgv", "nerdbank.gitversioning"],
			"groupName": "nbgv and nerdbank.gitversioning updates"
		},
		{
			"description": "Do not update the central AspNetCoreVersion property.",
			"matchManagers": ["nuget"],
			"matchFileNames": ["Directory.Packages.props"],
			"matchDepNames": ["AspNetCoreVersion"],
			"enabled": false
		},
		{
			"matchPackageNames": ["xunit*"],
			"groupName": "xunit"
		},
		{
			"matchPackageNames": ["Microsoft.Testing.Extensions.*"],
			"groupName": "Microsoft Testing Platform"
		},
		{
			"matchDatasources": ["dotnet-version", "docker"],
			"matchDepNames": ["dotnet-sdk", "mcr.microsoft.com/dotnet/sdk"],
			"groupName": "Dockerfile and global.json updates"
		}
	]
}
